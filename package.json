{
  "name": "minifolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "node --watch --watch-path=server --watch-path=vite.config.ts --watch-path=index.html --watch-preserve-output server/index.ts --dev",
    "build": "vite build --app",
    "start": "node dist/server/server.js",
    "check": "tsc -b --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "1.19.11",
    "fast-xml-parser": "^5.5.9",
    "hono": "4.12.9",
    "solid-js": "1.9.12",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vite-plugin-solid": "2.11.11"
  }
}